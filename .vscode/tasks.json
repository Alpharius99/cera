{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$tsc"
    },
    {
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": "$tsc-watch"
    },
    {
      "type": "npm",
      "script": "watch:webview",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": [{ "regexp": "^✘ \\[ERROR\\] (.*)$", "message": 1 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[watch\\] build started",
          "endsPattern": "\\[watch\\] build finished"
        }
      }
    },
    {
      "label": "watch all",
      "dependsOn": ["npm: watch", "npm: watch:webview"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
