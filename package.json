{
  "name": "cera",
  "displayName": "Cera",
  "description": "A distraction-free, reveal-on-focus Markdown editor for VS Code.",
  "version": "0.0.1",
  "publisher": "PavelSpakowski",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Alpharius99/cera.git"
  },
  "homepage": "https://github.com/Alpharius99/cera#readme",
  "bugs": {
    "url": "https://github.com/Alpharius99/cera/issues"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "editor",
    "wysiwyg",
    "zen",
    "distraction-free",
    "custom editor",
    "codemirror",
    "notes",
    "preview"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:cera.welcome"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cera",
          "title": "Cera",
          "icon": "media/cera-icon.svg"
        }
      ]
    },
    "views": {
      "cera": [
        {
          "id": "cera.welcome",
          "name": "Welcome"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "cera.welcome",
        "contents": "Cera is a distraction-free, reveal-on-focus Markdown editor.\n\n[New Document](command:cera.newDocument)\n[Open a Markdown File](command:cera.openMarkdownFile)\n\nAlready have a file open?\n[Open Current File in Cera](command:cera.openWith)"
      }
    ],
    "customEditors": [
      {
        "viewType": "cera.markdownEditor",
        "displayName": "Cera Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "cera.openWith",
        "title": "Cera: Open Current File in Cera Editor"
      },
      {
        "command": "cera.newDocument",
        "title": "Cera: New Document"
      },
      {
        "command": "cera.openMarkdownFile",
        "title": "Cera: Open a Markdown File"
      }
    ],
    "configuration": {
      "title": "Cera",
      "properties": {
        "cera.images.remote": {
          "type": "string",
          "enum": [
            "render",
            "placeholder"
          ],
          "enumDescriptions": [
            "Load remote (https) images directly.",
            "Show a click-to-load placeholder instead of loading remote images."
          ],
          "default": "render",
          "description": "How Cera handles remote (https) images. Local and inline (data:) images always render."
        },
        "cera.maxReadingWidth": {
          "type": "number",
          "default": 740,
          "minimum": 480,
          "maximum": 1400,
          "description": "Maximum width (in pixels) of the centered reading column."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "build:webview": "node esbuild.js",
    "watch": "tsc -watch -p ./",
    "watch:webview": "node esbuild.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "npm run build && node ./out/test/runTest.js",
    "test:all": "npm run build && npm test && node ./out/test/runTest.js",
    "package": "vsce package --out cera.vsix",
    "lint": "tsc -p ./ --noEmit"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.x",
    "@types/vscode": "^1.90.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.23.1",
    "glob": "^11.1.0",
    "jsdom": "^25.0.1",
    "mocha": "^10.8.2",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "dompurify": "^3.4.10",
    "markdown-it": "^14.2.0",
    "markdown-it-task-lists": "^2.1.1"
  }
}
