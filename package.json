{
  "name": "cera",
  "displayName": "Cera",
  "description": "A distraction-free, reveal-on-focus Markdown editor for VS Code.",
  "version": "0.0.1",
  "publisher": "Alpharius99",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Alpharius99/cera.git"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "editor",
    "wysiwyg",
    "zen",
    "distraction-free"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "cera.markdownEditor",
        "displayName": "Cera Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "cera.openWith",
        "title": "Cera: Open Current File in Cera Editor"
      }
    ],
    "configuration": {
      "title": "Cera",
      "properties": {
        "cera.images.remote": {
          "type": "string",
          "enum": ["render", "placeholder"],
          "enumDescriptions": [
            "Load remote (https) images directly.",
            "Show a click-to-load placeholder instead of loading remote images."
          ],
          "default": "render",
          "description": "How Cera handles remote (https) images. Local and inline (data:) images always render."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "build:webview": "node esbuild.js",
    "watch": "tsc -watch -p ./",
    "watch:webview": "node esbuild.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p ./ --noEmit"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.x",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.23.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "dompurify": "^3.4.10",
    "markdown-it": "^14.2.0",
    "markdown-it-task-lists": "^2.1.1"
  }
}
