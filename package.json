{
  "name": "cera",
  "displayName": "Cera",
  "description": "A distraction-free, reveal-on-focus Markdown editor for VS Code.",
  "version": "0.0.1",
  "publisher": "Alpharius99",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Alpharius99/cera.git"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "editor",
    "wysiwyg",
    "zen",
    "distraction-free"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "cera.markdownEditor",
        "displayName": "Cera Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "cera.openWith",
        "title": "Cera: Open Current File in Cera Editor"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run compile && npm run build:webview",
    "compile": "tsc -p ./",
    "build:webview": "node esbuild.js",
    "watch": "tsc -watch -p ./",
    "watch:webview": "node esbuild.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p ./ --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.23.1",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
